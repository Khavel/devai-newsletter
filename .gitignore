token-webmasters.json
token*.json

# --- Browser session / profile data (SECRETS: cookies, autofill) ---
seo/.reddit-profile/
seo/.reddit-cookies.json
seo/*-cookies.json
seo/.*-cookies.json

# --- Reddit runtime scratch / debug artifacts ---
seo/.reddit-*-out.json
seo/.reddit-result.txt
seo/.reddit-comment-draft.txt
seo/.reddit-replies-out.json
seo/reddit_*_debug.html
seo/reddit_*_debug.png
