seo/reddit_current.png
seo/reddit_composer_debug.png
seo/reddit_comment_posted.png
seo/reddit_session_check.png

# --- Operational logs (append-only runtime records; not code) ---
seo/twitter_post_log.jsonl
seo/twitter_engagement_log.jsonl
seo/reddit_comment_log.jsonl
seo/crosspost_log.jsonl

# --- Misc runtime temp ---
seo/.tmp_media.png
seo/*.tmp
*.jsonl.tmp

# --- Serena / IDE tooling cache ---
.serena/cache/
.serena/

# keep .env.example tracked despite .env.* rule above
