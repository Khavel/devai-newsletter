# ============================================================
# DevAI Newsletter — Variables de entorno
# Copia este archivo a .env y rellena tus valores
# ============================================================

# Anthropic API Key (obligatoria)
# Obtén en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# MailerLite (necesario para --draft)
# API key: https://dashboard.mailerlite.com/integrations/api
# Sender email: debe estar verificado en MailerLite → Senders
MAILERLITE_API_KEY=
MAILERLITE_SENDER_EMAIL=
MAILERLITE_SENDER_NAME=DevAI

# Ghost (para publicar el newsletter en la web)
# Admin API key: Ghost Admin → Settings → Integrations → Custom integration
GHOST_URL=https://devaisemanal.com
GHOST_ADMIN_API_KEY=

# Telegram (opcional — notificación al terminar)
# Crea un bot con @BotFather y obtén el chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
