# ============================================================
# DevAI Newsletter — Variables de entorno
# Copia este archivo a .env y rellena tus valores
# ============================================================

# Anthropic API Key (obligatoria)
# Obtén en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Beehiiv (solo necesario para --draft)
# Obtén en: https://app.beehiiv.com/settings/integrations
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Telegram (opcional — notificación al terminar en modo --preview)
# Crea un bot con @BotFather y obtén el chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
